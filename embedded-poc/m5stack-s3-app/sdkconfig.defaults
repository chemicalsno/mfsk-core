# M5StickS3 IC-705 FT8 コントローラ — sdkconfig defaults.
#
# 前提: 兄弟クレート `m5stack-s3` (compute bench) の sdkconfig をベース
# に、本アプリ向けに **BLE central** と **USB host** を有効化、partition
# table に littlefs を追加。WiFi は当面オフのまま。

CONFIG_ESP_MAIN_TASK_STACK_SIZE=32768

# ── Flash + partition table ──────────────────────────────────────────
# M5StickS3 = ESP32-S3-PICO-1-N8R8 (8 MB flash, 8 MB Octal PSRAM).
# Earlier bootloader run reported "SPI Flash Size: 4 MB" — that was a
# stale bootloader.bin built before this sdkconfig change took effect.
# Force-rebuild via `cargo clean -p esp-idf-sys` if you see the same.
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="/home/minoru/src/mfsk-core/embedded-poc/m5stack-s3-app/partitions.csv"

CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=4096
CONFIG_PTHREAD_TASK_STACK_SIZE_DEFAULT=4096

# ── Bluetooth (BLE only, NimBLE host) ────────────────────────────────
# IC-705 CI-V を BLE GATT (K7MDL2 方式) で叩くため central として動作。
# Bluedroid ではなく NimBLE を選択 — RAM 使用量が小さく、esp32-nimble
# クレートが薄くラップしている。
CONFIG_BT_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=n
CONFIG_BT_NIMBLE_ENABLED=y
# Central のみ。peripheral / observer / broadcaster は不要。
CONFIG_BT_NIMBLE_ROLE_CENTRAL=y
CONFIG_BT_NIMBLE_ROLE_OBSERVER=n
CONFIG_BT_NIMBLE_ROLE_PERIPHERAL=n
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=n

# ── Networking ───────────────────────────────────────────────────────
# WiFi/IP は MVP では不要。Phase 5 以降で QSO 即時 push が要るなら有効化。
CONFIG_ESP_WIFI_ENABLED=n
CONFIG_LWIP_TCP_ENABLED=n
CONFIG_LWIP_UDP_ENABLED=n

# ── USB Host (UAC capture) ───────────────────────────────────────────
# IC-705 の USB Audio Class endpoint を ESP32-S3 USB-OTG host で受ける。
# Phase 1 の最大ブロッカ。recipe.c (espressif/esp_usb_audio) を Rust
# 経由で叩く。
CONFIG_USB_HOST_ENABLED=y

# ── PSRAM (Octal 8 MB) ────────────────────────────────────────────────
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_USE_MALLOC=y
# 兄弟クレート (compute bench) と同じく 4096 — dual-core decode で
# stage 3 cs Box (5 KB × 15 × 2) が内蔵 DRAM に貼り付くと tlsf 破壊。
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=4096

# ── Task watchdog ────────────────────────────────────────────────────
# ライブ RX は task ごとに yield する設計なので WDT は ON のままでよい。
# Phase 1 で長時間 isochronous loop を組む際に再評価。
# CONFIG_ESP_TASK_WDT_INIT=y  (default)

# ── esp-dsp FFT — 8192 twiddle table ─────────────────────────────────
CONFIG_DSP_MAX_FFT_SIZE_8192=y
