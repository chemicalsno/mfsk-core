# Rust often needs a bit of an extra main task stack size compared to C
# (the default is 3K). decode_block allocates a 372×4096 f32 spectrogram
# in the heap, not the stack — but the planner / cw / tov scratch in BP
# is heap too. 16K was sweep-margin-tight: a full 9-decode sweep tripped
# `A stack overflow in task main` right at `=== Sweep complete ===` even
# after replacing `std::thread::sleep` with direct `vTaskDelay`. 32K
# gives comfortable headroom.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=32768

# ── Flash + partition table ──────────────────────────────────────────
# M5StickS3 = ESP32-S3-PICO-1-N8R8 (8 MB flash). Default singleapp
# table reserves only 1 MB factory, but rx-wavsim flash payload is
# ~1.77 MB on LX7 (vs ~0.9 MB on LX6 — esp-dsp PIE SIMD variants +
# chip driver code). Custom partitions.csv gives 2 MB factory.
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="/home/minoru/src/mfsk-core/embedded-poc/m5stack-s3/partitions.csv"

CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=4096
CONFIG_PTHREAD_TASK_STACK_SIZE_DEFAULT=4096

# ── Disable unused subsystems to free internal SRAM ──────────────────
# decode_block wants the audio slot (360 KB) in internal SRAM for
# speed (Octal PSRAM ~80 MB/s vs internal SRAM ~hundreds MB/s).
# Default IDF config holds BT/WiFi/LWIP buffers in internal RAM —
# disable everything we don't use to keep the ample S3 DRAM free
# for stage 3 per-candidate workspace pinning (issue #15 Phase 5).
CONFIG_BT_ENABLED=n
CONFIG_ESP_WIFI_ENABLED=n
CONFIG_LWIP_TCP_ENABLED=n
CONFIG_LWIP_UDP_ENABLED=n

# ── PSRAM (M5Stack S3 系は 8 MB Octal PSRAM 想定) ──────────────────────
# decode_block needs ~6 MB peak heap (372 × 8192 × 4 = 12 MB
# spectrogram dropped before per-candidate DFT). Internal SRAM is
# bigger on S3 (~512 KB DRAM after ROM/IROM split, vs LX6 ~280 KB
# usable) but still too small for the spec buffer. S3 PSRAM は Octal
# (理論帯域 ~80 MB/s、LX6 Quad の倍) で、PIE SIMD と独立に PSRAM
# hot path も楽になる見込み。Quad PSRAM の S3 ボード (M5Stamp S3 等)
# を使う場合は `_MODE_QUAD=y` に切替。
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_USE_MALLOC=y
# Honor PSRAM-allocated buffers from `Box<[T]>` / `Vec<T>` automatically.
# Lowered 16384 → 4096 for dual-core decode (`dual_core.rs`): both
# `pass2_split` halves hold ≤ 15 cs Box of 5 KB each in
# `refine_candidates_with`'s BinaryHeap simultaneously. With
# 16384 these 5 KB allocations stayed in internal DRAM (60 KB peak
# per half × 2 cores = 120 KB), exhausting the ~111 KB free
# contiguous DRAM and corrupting tlsf — Guru Meditation
# LoadProhibited at the Pass 2 → Stage 3 transition. At 4096 the
# cs Boxes route to PSRAM; they're only read once when packing
# RefinedCandidate so the bandwidth hit is negligible.
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=4096

# ── Task watchdog ────────────────────────────────────────────────────
# decode_block is a long-running compute kernel that doesn't yield —
# the default 5-second task watchdog will fire even on a normal run.
# Disable for the test bench; production builds (live RX) re-enable
# and yield via vTaskDelay between slot stages.
CONFIG_ESP_TASK_WDT_INIT=n

# ── esp-dsp FFT — extended twiddle table ─────────────────────────────
# decode_block uses NFFT_SPEC=8192 for the spectrogram FFT. The
# espressif/esp-dsp Kconfig knob is `DSP_MAX_FFT_SIZE` (NOT the
# fictitious `DSP_TABLE_SIZE_4096_TO_32768` name carried in the S3
# PoC's comment — that flag does nothing). Default is 4096; bump to
# 8192 so `dsps_fft2r_init_fc32(NULL, 8192)` returns ESP_OK.
CONFIG_DSP_MAX_FFT_SIZE_8192=y
